{
  "name": "remotion-server",
  "version": "1.0.0",
  "description": "Remotion render server for Flujo Imagen - Xpertia Tech",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npx remotion bundle src/remotion/index.ts --out-dir=build/bundle",
    "start": "node --max-old-space-size=3072 dist/server.js",
    "studio": "npx remotion studio src/remotion/index.ts"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/fonts": "^4.0.443",
    "@remotion/google-fonts": "^4.0.443",
    "@remotion/renderer": "^4.0.0",
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
